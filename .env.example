# Required for Prisma and for `pnpm build`, because admin pages read Prisma data during prerender.
DATABASE_URL="postgresql://directbuy:directbuy_password@localhost:5432/directbuy"

# Required for the Telegram bot and Telegram admin auth.
BOT_TOKEN="replace-with-telegram-bot-token"
NEXT_PUBLIC_BOT_USERNAME="mo_lot_bot"

# Admin/API auth placeholders.
ADMIN_SESSION_TOKEN="replace-with-admin-session-token"
ADMIN_API_KEY="replace-with-admin-api-key"

# Optional integrations.
REDIS_URL="redis://localhost:6379"
DADATA_API_KEY=""
LOG_LEVEL="info"
