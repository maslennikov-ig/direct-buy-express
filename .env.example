# Direct Buy production docker-compose environment.
# Copy to .env on the VPS and replace placeholder values there. Never commit real values.

# Public hostname served by Caddy. DNS A/AAAA records must point to the VPS.
DOMAIN=directbuy.example.com

# PostgreSQL container bootstrap.
POSTGRES_USER=directbuy
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=directbuy

# Local non-Compose fallback for Prisma scripts and development commands.
DATABASE_URL=postgresql://directbuy:directbuy_password@localhost:5432/directbuy
REDIS_URL=redis://localhost:6379

# Telegram bot and admin authentication.
BOT_TOKEN=replace-with-botfather-token
NEXT_PUBLIC_BOT_USERNAME=directbuy_bot
ADMIN_SESSION_TOKEN=replace-with-random-session-token
ADMIN_API_KEY=replace-with-random-api-key

# Initial application settings seeded into the Setting table on first deploy.
# Existing database values are not overwritten by the seed command.
MANAGER_CHAT_ID=123456789,987654321
PLATFORM_FEE_RUB=100000
SLA_DOCS_UPLOAD_HOURS=2
SLA_INVESTOR_REVIEW_HOURS=24
SLA_OFFER_RESPONSE_HOURS=2
BOT_ACTIVE=true

# Optional integrations and runtime tuning.
DADATA_API_KEY=
LOG_LEVEL=info
